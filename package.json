{
  "name": "pi-tau",
  "version": "2.4.0",
  "description": "τ (tau = 2π): Quality-of-Life Extension for pi. Background tasks, notifications, pill-bar status, task management, and web browsing.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "author": "Joseph Mearman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mearman/tau.git"
  },
  "files": [
    "src/",
    "chrome-extension/",
    "bridge/",
    "docs/",
    "install.sh",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "test": "node --experimental-strip-types --test --test-force-exit 'src/__tests__/*.test.ts'",
    "test:coverage": "c8 pnpm test",
    "check": "tsc --noEmit",
    "lint": "eslint --cache",
    "lint:fix": "eslint --cache --fix",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.91.1",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@types/node": "25.6.2",
    "c8": "^11.0.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "typebox": "^1.1.24",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1"
  },
  "packageManager": "pnpm@10.33.1",
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.169",
    "cloakbrowser": "0.3.29",
    "patchright": "1.60.0"
  },
  "dependencies": {
    "marked": "15.0.12",
    "playwright-core": "1.60.0"
  }
}
